# Rubika Group Manager Bot - Configuration Example
# This is a fully populated example of the .env file
# Copy this to .env and update with your actual values

# ============================================================
# BOT CONFIGURATION
# ============================================================

# Bot Token from Rubika Bot Manager
# Get this from: https://rubika.ir (Bot Manager section)
# IMPORTANT: Keep this secret! Never share or commit this!
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh

# ============================================================
# GROUP CONFIGURATION
# ============================================================

# Group Chat IDs (comma-separated)
# These are the groups the bot will monitor
# To find Chat ID:
#   1. Send a message in the group
#   2. Check the logs when bot is running
#   3. Or use @GroupGuide bot in the group
GROUP_CHAT_IDS=123456789,987654321,555555555

# ============================================================
# USER ROLES
# ============================================================

# Admin User IDs (comma-separated)
# Admins have full control over all commands
# Including /promote, /demote
ADMIN_USERS=111111111,222222222

# Moderator User IDs (comma-separated)
# Moderators can use: /kick, /ban, /warn, /mute
# But cannot use: /promote, /demote
MODERATOR_USERS=333333333,444444444,555555555

# ============================================================
# CONTENT FILTERING
# ============================================================

# Banned Words (comma-separated)
# Words that will trigger automatic moderation
# Case-insensitive matching
# Example with Persian:
BANNED_WORDS=spam,abuse,harassment,فحش,توهین,کلمه‌نامناسب

# Auto-delete messages containing banned words
# true = delete automatically
# false = just warn without deleting
AUTO_DELETE_BANNED_CONTENT=true

# Send warning message when banned word is detected
# true = send warning message
# false = silent moderation
WARN_ON_BANNED_WORD=true

# ============================================================
# WARNING SYSTEM
# ============================================================

# Number of warnings before automatic ban
# When a user reaches this limit, they are automatically banned
# Example: 3 means after 3 warnings, user is banned
WARNING_LIMIT=3

# ============================================================
# LOGGING CONFIGURATION
# ============================================================

# Enable or disable logging
# true = all activities will be logged
# false = no logging
ENABLE_LOGGING=true

# Log file name
# Logs will be saved in logs/ directory
# Created automatically if doesn't exist
LOG_FILE=group_manager.log

# ============================================================
# RESPONSE MESSAGES (in Persian)
# ============================================================

# Welcome message for new members
# Can include welcome text and group rules
WELCOME_MESSAGE=خوش آمدید به گروه! 👋\nلطفا قوانین و دستورالعمل‌های زیر را رعایت کنید:\n- رعایت احترام و تجاهز نکردن\n- ارسال اسپم ممنوع است\n- پرسش سوالات مربوطه

# Message when user is banned
BAN_MESSAGE=🚫 این کاربر به دلیل نقض شدید قوانین گروه مسدود شد

# Message when user is kicked
KICK_MESSAGE=⚠️ این کاربر از گروه اخراج شد

# Warning message format
# {count} = current warning count
# {limit} = total warning limit
WARN_MESSAGE=⚠️ هشدار: {count}/{limit}\nاگر دوباره قوانین را نقض کنید، مسدود می‌شوید

# ============================================================
# ADDITIONAL SETTINGS (Optional)
# ============================================================

# Rate limiting (optional)
# Prevent spam and abuse
RATE_LIMIT_ENABLED=true
MAX_MESSAGES_PER_MINUTE=10

# Auto-backup warnings (optional)
# Backup user warning data periodically
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24

# ============================================================
# NOTES
# ============================================================
#
# 1. BOT TOKEN:
#    - Never share this token publicly
#    - Never commit it to version control
#    - Use environment variables in production
#
# 2. GROUP CHAT IDS:
#    - Separate multiple groups with commas
#    - No spaces around commas
#    - Example: 123,456,789
#
# 3. ADMIN/MODERATOR IDS:
#    - These are user IDs, not usernames
#    - Get from bot logs or Rubika API
#    - Can specify multiple IDs separated by commas
#
# 4. BANNED WORDS:
#    - Case-insensitive
#    - Supports Persian and English
#    - Separate with commas
#
# 5. MESSAGES:
#    - Use \n for line breaks
#    - Use emojis for visual appeal
#    - Support Persian (RTL) text
#
# ============================================================
